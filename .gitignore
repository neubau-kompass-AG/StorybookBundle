# PHP dependencies and local runtime state.
/vendor/
/vendor-bin/*/vendor/
/var/
/composer.lock
/symfony.lock

# JavaScript installs are intentionally not committed; lockfiles are committed.
/node_modules
/packages/*/node_modules

# JavaScript build output and test artefacts.
/storybook-static
/coverage

# Local test/tool output.
/.phpunit.result.cache
/phpunit.xml
/tests/Fixtures/config/reference.php

.php-cs-fixer.cache
/.phpactor.json

# Local environment overrides.
.env
.env.*
**/.env
**/.env.*
!.env.example
!.env.dist

# OS and editor files.
.DS_Store
Thumbs.db
.idea/
.vscode/
.fleet/
*.iml
*.swp
*.swo
