{
    "version": "0.1.1",
    "name": "@neubau-kompass/storybook-symfony-webpack",
    "type": "module",
    "description": "Storybook for Symfony",
    "author": "neubau kompass AG",
    "homepage": "https://github.com/neubau-kompass-AG/StorybookBundle#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/neubau-kompass-AG/StorybookBundle.git",
        "directory": "packages/webpack"
    },
    "bugs": {
        "url": "https://github.com/neubau-kompass-AG/StorybookBundle/issues"
    },
    "keywords": [
        "storybook",
        "symfony"
    ],
    "license": "MIT",
    "scripts": {
        "build": "rimraf ./dist && tsup",
        "build:watch": "tsup --watch",
        "clean": "rimraf ./dist",
        "lint": "eslint src",
        "format": "prettier \"src/**/*.ts\" \"*.{json,md}\" \"src/*/*.{json,md}\" --write --no-error-on-unmatched-pattern",
        "test": "vitest --run",
        "check-format": "prettier \"src/**/*.ts\" \"*.{json,md}\" \"src/*/*.{json,md}\" --no-write --check --no-error-on-unmatched-pattern",
        "check-lint": "eslint src --no-fix"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./preset": {
            "types": "./dist/preset.d.ts",
            "default": "./dist/preset.js"
        },
        "./package.json": "./package.json"
    },
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist/**/*",
        "README.md",
        "preset.js"
    ],
    "dependencies": {
        "@storybook/builder-webpack5": "10.3.5",
        "@storybook/core-webpack": "10.3.5",
        "@storybook/global": "5.0.0",
        "css-loader": "6.11.0",
        "fast-xml-parser": "5.7.2",
        "glob": "10.5.0",
        "html-webpack-plugin": "5.6.0",
        "http-proxy-middleware": "3.0.5",
        "is-glob": "4.0.3",
        "jsdom": "29.1.0",
        "node-polyfill-webpack-plugin": "4.1.0",
        "storybook": "10.3.5",
        "ts-dedent": "2.2.0",
        "tsconfig-paths": "4.2.0",
        "tsconfig-paths-webpack-plugin": "4.2.0",
        "unplugin": "1.16.1",
        "webpack-virtual-modules": "0.6.2"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@neubau-kompass/storybook-symfony-shared": "file:../shared",
        "@types/he": "1.2.3",
        "@types/is-glob": "4.0.4",
        "@types/jest": "29.5.14",
        "@types/jsdom": "21.1.7",
        "@types/loader-utils": "2.0.6",
        "@types/node": "24.10.0",
        "@typescript-eslint/eslint-plugin": "8.59.1",
        "@typescript-eslint/parser": "8.59.1",
        "eslint": "10.2.1",
        "eslint-config-prettier": "10.1.8",
        "he": "1.2.0",
        "prettier": "3.7.4",
        "rimraf": "5.0.10",
        "ts-node": "10.9.2",
        "tsup": "8.5.1",
        "typescript": "5.9.3",
        "vitest": "4.1.5",
        "vitest-mock-extended": "1.3.1",
        "webpack": "5.106.2"
    },
    "peerDependencies": {
        "storybook": "^10.0.0",
        "typescript": "^5.3.3",
        "webpack": "^5.0.0"
    },
    "peerDependenciesMeta": {
        "typescript": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "bundler": {
        "managerEntries": [
            "./src/entry-preview.ts",
            "./src/entry-preview-docs.ts"
        ],
        "nodeEntries": [
            "./src/preset.ts",
            "./src/server/framework-preset.ts",
            "./src/builders/webpack-builder.ts"
        ],
        "previewEntries": [
            "./src/index.ts"
        ]
    }
}
