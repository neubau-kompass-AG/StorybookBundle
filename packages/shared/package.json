{
    "version": "0.0.0",
    "name": "@sensiolabs/storybook-symfony-shared",
    "private": true,
    "type": "module",
    "description": "Shared internals for Storybook Symfony framework packages",
    "license": "MIT",
    "scripts": {
        "build": "rimraf ./dist && tsup",
        "build:watch": "tsup --watch",
        "clean": "rimraf ./dist",
        "lint": "eslint src",
        "format": "prettier \"src/**/*.ts\" \"*.{json,md}\" \"src/*/*.{json,md}\" --write --no-error-on-unmatched-pattern",
        "test": "vitest --run",
        "check-format": "prettier \"src/**/*.ts\" \"*.{json,md}\" \"src/*/*.{json,md}\" --no-write --check --no-error-on-unmatched-pattern",
        "check-lint": "eslint src --no-fix"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./entry-preview": {
            "types": "./dist/entry-preview.d.ts",
            "default": "./dist/entry-preview.js"
        },
        "./entry-preview-docs": {
            "types": "./dist/entry-preview-docs.d.ts",
            "default": "./dist/entry-preview-docs.js"
        },
        "./server/*": {
            "types": "./dist/*.d.ts",
            "default": "./dist/*.js"
        },
        "./server/lib/*": {
            "types": "./dist/lib/*.d.ts",
            "default": "./dist/lib/*.js"
        },
        "./package.json": "./package.json"
    },
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist/**/*",
        "README.md",
        "*.js",
        "*.d.ts",
        "!src/**/*"
    ],
    "dependencies": {
        "@storybook/global": "5.0.0",
        "fast-xml-parser": "5.7.2",
        "glob": "10.5.0",
        "he": "1.2.0",
        "html-webpack-plugin": "5.6.0",
        "is-glob": "4.0.3",
        "jsdom": "29.1.0",
        "storybook": "10.3.5",
        "ts-dedent": "2.2.0",
        "unplugin": "1.16.1",
        "webpack-virtual-modules": "0.6.2"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@types/he": "1.2.3",
        "@types/is-glob": "4.0.4",
        "@types/jest": "29.5.14",
        "@types/jsdom": "21.1.7",
        "@types/loader-utils": "2.0.6",
        "@types/node": "24.10.0",
        "@typescript-eslint/eslint-plugin": "8.59.1",
        "@typescript-eslint/parser": "8.59.1",
        "eslint": "10.2.1",
        "eslint-config-prettier": "10.1.8",
        "prettier": "3.7.4",
        "rimraf": "5.0.10",
        "ts-node": "10.9.2",
        "tsup": "8.5.1",
        "typescript": "5.9.3",
        "vitest": "4.1.5",
        "vitest-mock-extended": "1.3.1",
        "webpack": "5.106.2"
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "bundler": {
        "nodeEntries": [
            "./src/server/framework-options.ts",
            "./src/server/lib/computeAdditionalWatchPaths.ts",
            "./src/server/lib/dev-preview-compiler-plugin.ts",
            "./src/server/lib/extractComponentsFromTemplate.ts",
            "./src/server/lib/injectPreviewHtml.ts",
            "./src/server/lib/preview-compiler-plugin.ts",
            "./src/server/lib/symfony.ts",
            "./src/server/lib/twig-loader-plugin.ts",
            "./src/server/lib/TwigComponentResolver.ts"
        ],
        "previewEntries": [
            "./src/index.ts",
            "./src/entry-preview.ts",
            "./src/entry-preview-docs.ts"
        ]
    }
}
