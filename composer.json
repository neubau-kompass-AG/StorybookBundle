{
    "name": "neubau-kompass/storybook-bundle",
    "type": "library",
    "license": "MIT",
    "description": "Bundle to use Storybook with Symfony UX packages.",
    "authors": [
        {
            "name": "Nicolas Rigaud",
            "email": "squrious@protonmail.com"
        },
        {
            "name": "neubau kompass AG"
        }
    ],
    "autoload": {
        "psr-4": {
            "Storybook\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Storybook\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4",
        "symfony/console": "^8.0",
        "symfony/event-dispatcher": "^8.0",
        "symfony/filesystem": "^8.0",
        "symfony/http-foundation": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/ux-twig-component": "^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "symfony/asset-mapper": "^8.0",
        "symfony/browser-kit": "^8.0",
        "symfony/css-selector": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/phpunit-bridge": "^8.0",
        "symfony/stimulus-bundle": "^3.0",
        "symfony/ux-live-component": "^3.0",
        "symfonycasts/sass-bundle": "^0.9.0",
        "symfonycasts/tailwind-bundle": "^0.12.0",
        "friendsofphp/php-cs-fixer": "^3.95",
        "bamarni/composer-bin-plugin": "^1.8"
    },
    "config": {
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true
        }
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": true,
            "forward-command": false
        }
    }
}
